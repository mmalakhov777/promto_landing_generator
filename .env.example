# PostgreSQL
POSTGRES_DB=promto_landings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Backend
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/promto_landings
SECRET_KEY=change-me-in-production
REVALIDATE_SECRET=change-me-in-production

# Yandex SmartCaptcha
SMARTCAPTCHA_SERVER_KEY=

# Frontend — server-side (internal Docker network)
API_URL=http://backend:8000

# Frontend — client-side (public URL, exposed to browser JS)
NEXT_PUBLIC_API_URL=https://types.promto.ai
